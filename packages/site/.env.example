# Ophillia Site — Environment Variables
# Copy to .env and fill in values before running

# PocketBase backend URL
NUXT_PUBLIC_PB_URL=http://localhost:8090

# API key for PocketBase (use a user/admin token)
NUXT_PUBLIC_API_KEY=

# Slug of the project in PocketBase
NUXT_PUBLIC_PROJECT_SLUG=my-project

# Secret token for enabling preview mode (?preview=<this value>)
NUXT_PUBLIC_PREVIEW_SECRET=change-me-to-a-secret
