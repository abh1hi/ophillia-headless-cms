{
    "name": "@ophillia/sdk",
    "version": "1.0.0",
    "description": "TypeScript SDK for Ophillia HCMS",
    "main": "dist/index.js",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "scripts": {
        "build": "tsup src/index.ts --format cjs,esm --dts",
        "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
        "test": "vitest run",
        "lint": "eslint src/"
    },
    "devDependencies": {
        "@types/node": "^25.3.3",
        "@vitest/coverage-v8": "^4.0.18",
        "tsup": "^8.5.1",
        "typescript": "^5.9.3",
        "vitest": "^4.0.18"
    }
}